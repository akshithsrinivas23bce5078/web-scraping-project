q;:null}]}],&q;subtitle&q;:null,&q;description&q;:null,&q;publisherImprint&q;:&q;Apple Academic Press&q;,&q;publicationDate&q;:null,&q;copyright&q;:{&q;holder&q;:&q;Apple Academic Press, Inc.&q;,&q;year&q;:2026,&q;statement&q;:&q;© 2026 by Apple Academic Press, Inc.&q;},&q;edition&q;:1,&q;doiRegistrationStatus&q;:false,&q;firstPublishedYear&q;:&q;2026&q;,&q;plannedPublicationDate&q;:&q;2026-06-09T00:00:00.000Z&q;,&q;abstracts&q;:[{&q;type&q;:&q;xml&q;,&q;position&q;:0,&q;caption&q;:null,&q;transcript&q;:null,&q;textType&q;:&q;abstract&q;,&q;value&q;:&q;&l;p&g;The increasing popularity of hill stations in the Indian Himalayan region has led to amplified visitor activities, resulting in degradation of environment, cultural disruption, and challenges related to destination management. The Indian Himalayan states have adopted ecotourism as a sustainable strategy for rural development and environmental conservation. Previous studies have proposed the potential of rural tourism, nature tourism, community-based ecotourism, and homestay initiatives as models toward sustainable tourism development. Sustainable homestays in Sikkim and the Darjeeling hills function as integral components of community-based ecotourism, actively fostering community participation, enhancing environmental consciousness, preserving cultural heritage, and facilitating the growth of local micro and small enterprises. Homestays serve as vital ecotourism product that promote ecological and cultural preservation while delivering shared economic benefits, particularly to marginalised indigenous communities, through implementation of responsible tourism practices. However, limited academic research have evaluated sustainability dimensions of homestays using the triple bottom line (TBL) framework. This study examines responsible tourism practices and operational performance of homestays in Sikkim and Darjeeling hills, offering empirical data across economic, social, and environmental dimensions for sustainable tourism development in the Indian Himalayan region.&l;/p&g;&q;}],&q;citation&q;:&q;Bhutia, J.W., &a; Bhutia, S.G. (2026). Ecotourism and Sustainable Development in the Indian Himalayan Region: A Case Study of Sikkim and Darjeeling Hills. Himalayan Mountain Tourism: Toward Sustainable Adventure Tourism (pp. 79-94). Apple Academic Press. https://doi.org/10.1201/9781998511198-5&q;,&q;textType&q;:&q;Reference (DRM-Free)&q;},&q;identifiers&q;:{&q;doi&q;:&q;10.1201/9781998511198-5&q;,&q;chapterId&q;:&q;chap5&q;,&q;sku&q;:null},&q;isFree&q;:false,&q;associatedMedia&q;:[{&q;_id&q;:&q;46b8db16-ce03-4ac8-980d-7d0dd4b67324&q;,&q;type&q;:&q;chapterabstractxml&q;,&q;size&q;:1545,&q;location&q;:null},{&q;_id&q;:&q;2a2d53c7-5730-44d2-854a-6c3779e92a41&q;,&q;type&q;:&q;chapterpdf&q;,&q;size&q;:801467,&q;location&q;:null},{&q;_id&q;:&q;1d4042fb-abd7-4ae6-a790-0dd5d79a8cf7&q;,&q;type&q;:&q;coverimage&q;,&q;size&q;:27930,&q;location&q;:&q;https://images.tandf.co.uk/common/jackets/crclarge/978199851/9781998511198.jpg&q;},{&q;_id&q;:&q;286a8c4a-c007-45af-a8dc-5a97f7b1e645&q;,&q;type&q;:&q;dbitsxml&q;,&q;size&q;:77179,&q;location&q;:null}],&q;availability&q;:[{&q;name&q;:&q;EDI-EBSCO&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;INVALID_FORMAT&q;],&q;type&q;:&q;product&q;},{&q;name&q;:&q;EDI-Apollo&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;INVALID_FORMAT&q;],&q;type&q;:&q;product&q;},{&q;name&q;:&q;DigitalScience&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;INVALID_STATUS&q;],&q;type&q;:&q;content&q;},{&q;name&q;:&q;LOGPRO&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;INVALID_FORMAT&q;],&q;type&q;:&q;product&q;},{&q;name&q;:&q;SF OMS&q;,&q;status&q;:[&q;NOT_YET_PUBLISHED&q;],&q;errors&q;:[&q;PLANNED_BUT_NOT_YET_PUBLISHED&q;,&q;INVALID_FORMAT&q;],&q;type&q;:&q;product&q;},{&q;name&q;:&q;EDI-Amazon&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;INVALID_FORMAT&q;],&q;type&q;:&q;product&q;},{&q;name&q;:&q;EBSCO&q;,&q;status&q;:[&q;INVALID&q;],&q;errors&q;:[&q;NOT_RHO_