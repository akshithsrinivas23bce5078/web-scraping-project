  <script>
    self.airgap = {
      overrides: [],
      cookieOverrides: [],
      ...self.airgap,
    };
    const allowGcmAdvanced = (event) => {
      if (event.purposes.has('GcmAdvanced')) {
        event.allow();
      }
    };
    self.airgap.overrides.push({ override: allowGcmAdvanced });
    self.airgap.cookieOverrides.push(allowGcmAdvanced);
  </script>
